{
  "name": "dns-tools",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "description": "A self-hostable collection of DNS lookup and troubleshooting tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/version127/dns-tools.git"
  },
  "homepage": "https://version127.com/dns-tools",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev -p 1273",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit && npm run test:repo",
    "test:unit": "node --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "test:repo": "node scripts/verify-repository.mjs",
    "test:e2e": "playwright test",
    "test:live": "node scripts/live-smoke.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "test:server": "NEXT_PUBLIC_SITE_URL=http://127.0.0.1:1274 DNS_TOOLS_ALLOW_INDEXING=false next dev -p 1274",
    "quality": "npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@namefi/dnssec-audit": "^2.1.1",
    "dns-packet": "^5.6.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@types/dns-packet": "^5.6.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
